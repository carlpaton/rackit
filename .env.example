# MongoDB Atlas connection string
# Create a free cluster at https://cloud.mongodb.com, then copy the connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rackit?retryWrites=true&w=majority

# Random secret used to sign cookies and JWTs
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Canonical app URL
# Use http://localhost:3000 for local dev
# Use your Vercel deployment URL in production (e.g. https://rackit.vercel.app)
NEXTAUTH_URL=http://localhost:3000
